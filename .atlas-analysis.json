  "keyFeatures": [
    "Composable component system (ChatModel, Tool, Retriever, Embedding, Prompt, Indexer, Document)",
    "Graph-based orchestration with DAG and Pregel execution modes supporting cycles",
    "Agent Development Kit (ADK) for building single and multi-agent systems",
    "Automatic stream processing — concatenation, boxing, merging, and fan-out across nodes",
    "Callback aspects for logging, tracing, and metrics at OnStart/OnEnd/OnError lifecycle points",
    "Interrupt/Resume for human-in-the-loop workflows with checkpoint-based state persistence",
    "Prebuilt agent patterns: DeepAgent, Supervisor, Plan-Execute",
    "Type-safe generics throughout — Graph[I, O], Chain[I, O], Workflow[I, O]"
  ],
  "publicApiSurface": [
    "compose.NewGraph[I, O]() *Graph[I, O]",
    "compose.NewChain[I, O]() *Chain[I, O]",
    "compose.NewWorkflow[I, O]() *Workflow[I, O]",
    "adk.NewChatModelAgent(ctx, *ChatModelAgentConfig) (Agent, error)",
    "adk.NewRunner(ctx, RunnerConfig) *Runner",
    "adk.Agent interface { Name, Description, Run }",
    "model.BaseChatModel interface { Generate, Stream }",
    "model.ToolCallingChatModel interface { BaseChatModel, WithTools }",
    "callbacks.Handler interface { OnStart, OnEnd, OnError, OnStartWithStreamInput, OnEndWithStreamOutput }",
    "callbacks.AppendGlobalHandlers(handlers ...Handler)",
    "compose.WithCheckPointStore(store CheckPointStore) GraphCompileOption",
    "schema.Message, schema.StreamReader[T]",
    "components/tool.BaseTool, InvokableTool",
    "components/retriever.Retriever",
    "components/embedding.Embedder",
    "adk/prebuilt/deep.New(ctx, *Config) (Agent, error)",
    "adk/prebuilt/supervisor.New(ctx, *Config) (Agent, error)"
  ]
